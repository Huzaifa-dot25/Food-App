{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=FoodDeliveryDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "FoodDeliveryApp",
    "Audience": "FoodDeliveryApp",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "UseSsl": true,
    "SenderEmail": "noreply@fooddelivery.com",
    "SenderName": "Food Delivery App",
    "Username": "your-email@gmail.com",
    "Password": "your-app-password"
  },
  "FirebaseSettings": {
    "CredentialFilePath": "firebase-adminsdk.json",
    "ProjectId": "your-firebase-project-id"
  },
  "FileStorage": {
    "UploadPath": "wwwroot/uploads",
    "BaseUrl": "https://localhost:5001/uploads"
  },
  "RateLimiting": {
    "AuthEndpointPermitLimit": 5,
    "AuthEndpointWindowSeconds": 60,
    "GlobalPermitLimit": 100,
    "GlobalWindowSeconds": 60
  },
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
