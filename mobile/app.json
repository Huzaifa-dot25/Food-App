{
  "expo": {
    "name": "FoodDelivery",
    "slug": "food-delivery",
    "version": "1.0.0",
    "scheme": "fooddelivery",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.fooddelivery",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to find nearby restaurants and track your delivery.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Used to track deliveries in background.",
        "NSCameraUsageDescription": "Used to upload food and profile photos.",
        "NSPhotoLibraryUsageDescription": "Used to upload food and profile photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.yourcompany.fooddelivery",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF6B35"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow FoodDelivery to use your location."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "http://localhost:5001/api",
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
